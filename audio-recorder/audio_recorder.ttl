@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

<https://xdiloc.github.io/dspx/audio-recorder>
	a lv2:Plugin ;
	doap:name "dspx audio recorder" ;
	doap:maintainer [
		foaf:name "xdiloc"
	] ;
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "enable" ;
		lv2:name "Record" ;
		lv2:default 0.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		lv2:portProperty lv2:toggled ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "format" ;
		lv2:name "Format" ;
		lv2:default 0.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 2.0 ;
		lv2:portProperty lv2:integer , lv2:enumeration ;
		lv2:scalePoint [
			rdfs:label "OGG Vorbis" ;
			rdf:value 0.0
		] , [
			rdfs:label "WAV PCM16" ;
			rdf:value 1.0
		] , [
			rdfs:label "FLAC PCM16" ;
			rdf:value 2.0
		] ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "quality" ;
		lv2:name "Quality / Compression" ;
		lv2:default 0.5 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 3 ;
		lv2:symbol "in_l" ;
		lv2:name "In L"
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 4 ;
		lv2:symbol "in_r" ;
		lv2:name "In R"
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 5 ;
		lv2:symbol "out_l" ;
		lv2:name "Out L"
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 6 ;
		lv2:symbol "out_r" ;
		lv2:name "Out R"
	] .
