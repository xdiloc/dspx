@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .

<https://xdiloc.github.io/dspx/omega-transients>
	a lv2:Plugin , lv2:DynamicsPlugin ;
	doap:name "dspx omega transients" ;
	doap:maintainer [
		foaf:name "xdiloc" ;
	] ;
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "attack" ;
		lv2:name "Attack Gain" ;
		lv2:default 1.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 10.0 ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "release" ;
		lv2:name "Release Time" ;
		lv2:default 10.0 ;
		lv2:minimum 0.1 ;
		lv2:maximum 100.0 ;
		units:unit units:ms ;
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 2 ;
		lv2:symbol "in_l" ;
		lv2:name "In L"
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 3 ;
		lv2:symbol "in_r" ;
		lv2:name "In R"
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 4 ;
		lv2:symbol "out_l" ;
		lv2:name "Out L"
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 5 ;
		lv2:symbol "out_r" ;
		lv2:name "Out R"
	] .
