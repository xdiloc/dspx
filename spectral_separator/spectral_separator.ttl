@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix pg:   <http://lv2plug.in/ns/ext/port-groups#> .

<https://xdiloc.github.io/dspx/spectral-separator>
	a lv2:Plugin , lv2:SpatialPlugin ;
	doap:name "dspx spectral separator" ;
	doap:maintainer [
		foaf:name "xdiloc" ;
	] ;
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "contrast" ;
		lv2:name "Contrast" ;
		lv2:default 2.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 20.0 ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "sharp" ;
		lv2:name "Presence" ;
		lv2:default 1.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 10.0 ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "mix" ;
		lv2:name "Dry Mix" ;
		lv2:default 0.85 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 3 ;
		lv2:symbol "tilt" ;
		lv2:name "Side Tilt" ;
		lv2:default 0.05 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 4 ;
		lv2:symbol "in_l" ;
		lv2:name "In L" ;
		lv2:designation pg:left ;
	] , [
		a lv2:AudioPort , lv2:InputPort ;
		lv2:index 5 ;
		lv2:symbol "in_r" ;
		lv2:name "In R" ;
		lv2:designation pg:right ;
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 6 ;
		lv2:symbol "out_l" ;
		lv2:name "Out L" ;
		lv2:designation pg:left ;
	] , [
		a lv2:AudioPort , lv2:OutputPort ;
		lv2:index 7 ;
		lv2:symbol "out_r" ;
		lv2:name "Out R" ;
		lv2:designation pg:right ;
	] .
